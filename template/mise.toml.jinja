[tools]
"cargo:cargo-audit" = "0.22.1"
"cargo:cargo-deny" = "0.19.0"
"cargo:cargo-hack" = "0.6.43"
"cargo:cargo-insta" = "1.46.3"
"cargo:cargo-llvm-cov" = "0.8.4"
"cargo:cargo-msrv" = "0.19.2"
"cargo:cargo-nextest" = "0.9.130"
"cargo:cargo-outdated" = "0.17.0"
"cargo:cargo-watch" = "8.5.3"
"cargo:cbindgen" = "0.29.2"
"cargo:leptosfmt" = "0.1.33"
"cargo:trunk" = "0.21.14"
"cargo:wasm-bindgen-cli" = "0.2.114"
"cargo:wasm-pack" = "0.14.0"
"github:WebAssembly/wabt" = "1.0.40"
"go:github.com/google/addlicense" = "1.2.0"

actionlint = "1.7.11"
bun = "1.3.10"
cargo-binstall = "1.17.7"
fd = "10.4.2"
go = "1.26.1"
golangci-lint = "2.11.3"
jq = "1.8.1"
python = "3.14.3"
"rust" = { version = "1.94.0", components = "rustfmt,clippy,llvm-tools,rust-src", targets = "wasm32-unknown-unknown" }
sccache = "0.14.0"
shellcheck = "0.11.0"
uv = "0.10.10"

[task_config]
includes = ["mise-tasks"]

[env]
LIBRARY_PATH = "${LIBRARY_PATH:-}:/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/lib:/opt/homebrew/opt/libiconv/lib"
MACOSX_DEPLOYMENT_TARGET = "11.0"
RUST_BACKTRACE = "1"
RUSTC_WRAPPER = "sccache"
SCCACHE_DIR = "$HOME/.cache/sccache"

[settings]
env_shell_expand = true
experimental = true
idiomatic_version_file_enable_tools = ["rust"]
