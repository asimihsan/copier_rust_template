[tools]
"cargo:cargo-audit" = { version = "0.22.1", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cargo-deny" = { version = "0.19.0", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cargo-hack" = { version = "0.6.44", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cargo-insta" = { version = "1.47.1", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cargo-llvm-cov" = { version = "0.8.5", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cargo-msrv" = { version = "0.19.3", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cargo-nextest" = { version = "0.9.132", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cargo-outdated" = { version = "0.17.0", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cargo-watch" = { version = "8.5.3", install_env = { RUSTC_WRAPPER = "" } }
"cargo:cbindgen" = { version = "0.29.2", install_env = { RUSTC_WRAPPER = "" } }
"cargo:leptosfmt" = { version = "0.1.33", install_env = { RUSTC_WRAPPER = "" } }
"cargo:trunk" = { version = "0.21.14", install_env = { RUSTC_WRAPPER = "" } }
"cargo:wasm-bindgen-cli" = { version = "0.2.115", install_env = { RUSTC_WRAPPER = "" } }
"cargo:wasm-pack" = { version = "0.14.0", install_env = { RUSTC_WRAPPER = "" } }
"github:WebAssembly/wabt" = "1.0.40"
"go:github.com/google/addlicense" = "1.2.0"

actionlint = "1.7.11"
bun = "1.3.11"
cargo-binstall = "1.17.9"
fd = "10.4.2"
go = "1.26.1"
golangci-lint = "2.11.4"
jq = "1.8.1"
python = "3.14.3"
"rust" = { version = "1.94.1", components = "rustfmt,clippy,llvm-tools,rust-src", targets = "wasm32-unknown-unknown" }
"github:kunobi-ninja/kache" = "0.7.0"
shellcheck = "0.11.0"
uv = "0.11.2"

[task_config]
includes = ["mise-tasks"]

[env]
LIBRARY_PATH = "${LIBRARY_PATH:-}:/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/lib:/opt/homebrew/opt/libiconv/lib"
MACOSX_DEPLOYMENT_TARGET = "11.0"
RUST_BACKTRACE = "1"
RUSTC_WRAPPER = "kache"

[settings]
env_shell_expand = true
experimental = true
idiomatic_version_file_enable_tools = ["rust"]
