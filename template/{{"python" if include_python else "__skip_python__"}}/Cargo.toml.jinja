[package]
name = "{{ project_slug }}-py"
version = "0.1.0"
edition = "2024"
license = "MPL-2.0"
rust-version = "1.85"
authors = ["{{ author_name }}"]

[lib]
name = "{{ project_slug_underscore }}_py"
crate-type = ["cdylib"]

[dependencies]
{{ project_slug }}-core = { path = "../core" }
pyo3 = { version = "0.23", features = ["extension-module", "abi3-py311"] }
